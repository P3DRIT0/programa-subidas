{
  "name": "script-vinted-wallapop",
  "version": "1.0.0",
  "description": "Aplicacion de escritorio para automatizar publicaciones en Wallapop",
  "main": "dist/main.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "npm run build && set ELECTRON_RUN_AS_NODE=&& electron .",
    "dev": "npm run build && set ELECTRON_RUN_AS_NODE=&& electron .",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder --win nsis"
  },
  "keywords": [
    "electron",
    "playwright",
    "wallapop",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright": "1.44.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.12.12",
    "electron": "28.3.3",
    "electron-builder": "24.13.3",
    "rimraf": "5.0.5",
    "typescript": "5.4.5"
  },
  "build": {
    "appId": "com.retrobay.scriptvintedwallapop",
    "productName": "Publicador Wallapop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "ui/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/playwright",
        "to": "playwright"
      }
    ],
    "win": {
      "icon": "ui/assets/retrobay-app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
